<div class="card mb-md">
    <div class="card-body" style="padding: var(--sp-sm) var(--sp-md);">
        <div class="d-flex justify-between align-center" style="flex-wrap: wrap; gap: var(--sp-sm);">
            <div class="filter-group d-flex gap-sm align-center">
                <span class="fw-500">Filtrele:</span>
                <button class="btn btn-outline-sm filter-btn active" data-filter="all">Tümü</button>
                <button class="btn btn-outline-sm filter-btn" data-filter="bekliyor">Bekleyenler</button>
                <button class="btn btn-outline-sm filter-btn" data-filter="onaylandi">Onaylananlar</button>
                <button class="btn btn-outline-sm filter-btn" data-filter="iptal">İptal Edilenler</button>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <h2 class="card-title">Randevu Talepleri</h2>
    </div>
    
    <div class="card-body p-0">
        <% if (appointments && appointments.length > 0) { %>
            <div class="table-responsive">
                <table class="table" id="appointmentsTable">
                    <thead>
                        <tr>
                            <th>Tarih</th>
                            <th>Müşteri</th>
                            <th>İletişim</th>
                            <th>Düğün Tarihi</th>
                            <th>Hizmet / Mesaj</th>
                            <th>Durum</th>
                            <th style="text-align: right;">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% appointments.forEach(app => { %>
                            <tr class="appointment-row" data-status="<%= app.status %>">
                                <td>
                                    <div class="fw-500"><%= app.appointment_date %></div>
                                    <div class="text-muted" style="font-size: 0.75rem;">Talep: <%= new Date(app.created_at).toLocaleDateString('tr-TR') %></div>
                                </td>
                                <td class="fw-500"><%= app.full_name %></td>
                                <td>
                                    <div><%= app.phone %></div>
                                    <div class="text-muted"><%= app.email %></div>
                                </td>
                                <td><%= app.wedding_date || '-' %></td>
                                <td>
                                    <% 
                                        let hizmetAd = app.service;
                                        if(app.service === 'gelinlik') hizmetAd = 'Gelinlik Seçimi';
                                        if(app.service === 'ozel-tasarim') hizmetAd = 'Özel Tasarım';
                                        if(app.service === 'tadilat') hizmetAd = 'Tadilat & Uyum';
                                        if(app.service === 'aksesuar') hizmetAd = 'Aksesuar & Styling';
                                    %>
                                    <span class="badge badge-secondary mb-sm"><%= hizmetAd %></span>
                                    <% if(app.message) { %>
                                        <div style="font-size: 0.85rem; white-space: pre-wrap; word-break: break-word; margin-top: 6px; color: var(--clr-text-muted);">
                                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align: middle; margin-right: 4px;"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
                                            <%= app.message %>
                                        </div>
                                    <% } %>
                                </td>
                                <td>
                                    <form action="/admin/appointments/status/<%= app.id %>" method="POST" class="status-form">
                                        <select name="status" class="form-control" style="padding: 4px 8px; font-size: 0.8rem; width: 110px;" onchange="this.form.submit()">
                                            <option value="bekliyor" <%= app.status === 'bekliyor' ? 'selected' : '' %>>Bekliyor</option>
                                            <option value="onaylandi" <%= app.status === 'onaylandi' ? 'selected' : '' %>>Onaylandı</option>
                                            <option value="iptal" <%= app.status === 'iptal' ? 'selected' : '' %>>İptal</option>
                                        </select>
                                    </form>
                                    
                                    <div class="mt-sm">
                                        <% if(app.status === 'bekliyor') { %>
                                            <span class="badge badge-warning" style="width: 100%; text-align: center;">Bekliyor</span>
                                        <% } else if(app.status === 'onaylandi') { %>
                                            <span class="badge badge-success" style="width: 100%; text-align: center;">Onaylandı</span>
                                        <% } else if(app.status === 'iptal') { %>
                                            <span class="badge badge-danger" style="width: 100%; text-align: center;">İptal</span>
                                        <% } %>
                                    </div>
                                </td>
                                <td style="text-align: right;">
                                    <form action="/admin/appointments/delete/<%= app.id %>" method="POST" style="display: inline;" onsubmit="return confirm('Bu randevu talebini silmek istediğinize emin misiniz? Bu işlem geri alınamaz.');">
                                        <button type="submit" class="btn-icon text-danger" title="Sil">
                                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        <% } else { %>
            <div class="empty-state">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="mb-sm text-muted"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                <p>Hiç randevu talebi bulunmuyor.</p>
            </div>
        <% } %>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const filterBtns = document.querySelectorAll('.filter-btn');
    const rows = document.querySelectorAll('.appointment-row');
    
    filterBtns.forEach(btn => {
        btn.addEventListener('click', function() {
            // Update active state
            filterBtns.forEach(b => b.classList.remove('active'));
            this.classList.add('active');
            
            const filter = this.dataset.filter;
            
            // Filter rows
            let visibleCount = 0;
            rows.forEach(row => {
                if (filter === 'all' || row.dataset.status === filter) {
                    row.style.display = '';
                    visibleCount++;
                } else {
                    row.style.display = 'none';
                }
            });
            
            // Optional: show empty state if 0 results
        });
    });
});
</script>
