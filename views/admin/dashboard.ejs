<div class="dashboard-stats">
    <div class="stat-card">
        <div class="stat-icon stat-icon-dresses">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
        </div>
        <div class="stat-content">
            <h3 class="stat-number"><%= dressCount %></h3>
            <p class="stat-label">Toplam Gelinlik</p>
        </div>
    </div>
    
    <div class="stat-card">
        <div class="stat-icon stat-icon-pending">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
        </div>
        <div class="stat-content">
            <h3 class="stat-number"><%= pendingCount %></h3>
            <p class="stat-label">Bekleyen Randevu</p>
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-icon stat-icon-appointments">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
        </div>
        <div class="stat-content">
            <h3 class="stat-number"><%= totalAppointments %></h3>
            <p class="stat-label">Toplam Randevu</p>
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-icon stat-icon-testimonials">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
        </div>
        <div class="stat-content">
            <h3 class="stat-number"><%= testimonialCount %></h3>
            <p class="stat-label">Müşteri Yorumu</p>
        </div>
    </div>
</div>

<div class="card mt-lg">
    <div class="card-header d-flex justify-between align-center">
        <h2 class="card-title">Son Gelen Randevular</h2>
        <a href="/admin/appointments" class="btn btn-outline-sm">Tümünü Gör</a>
    </div>
    <div class="card-body p-0">
        <% if (recentAppointments && recentAppointments.length > 0) { %>
            <div class="table-responsive">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Ad Soyad</th>
                            <th>Telefon</th>
                            <th>Randevu Tarihi</th>
                            <th>Hizmet</th>
                            <th>Durum</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% recentAppointments.forEach(app => { %>
                            <tr>
                                <td class="fw-500"><%= app.full_name %></td>
                                <td><%= app.phone %></td>
                                <td><%= app.appointment_date %></td>
                                <td>
                                    <% 
                                        let hizmetAd = app.service;
                                        if(app.service === 'gelinlik') hizmetAd = 'Gelinlik Seçimi';
                                        if(app.service === 'ozel-tasarim') hizmetAd = 'Özel Tasarım';
                                        if(app.service === 'tadilat') hizmetAd = 'Tadilat & Uyum';
                                        if(app.service === 'aksesuar') hizmetAd = 'Aksesuar & Styling';
                                    %>
                                    <%= hizmetAd %>
                                </td>
                                <td>
                                    <% if(app.status === 'bekliyor') { %>
                                        <span class="badge badge-warning">Bekliyor</span>
                                    <% } else if(app.status === 'onaylandi') { %>
                                        <span class="badge badge-success">Onaylandı</span>
                                    <% } else if(app.status === 'iptal') { %>
                                        <span class="badge badge-danger">İptal</span>
                                    <% } %>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        <% } else { %>
            <div class="empty-state">
                <p>Henüz randevu bulunmuyor.</p>
            </div>
        <% } %>
    </div>
</div>
