<div class="card">
    <div class="card-header d-flex justify-between align-center">
        <h2 class="card-title">Koleksiyon (Gelinlikler)</h2>
        <a href="/admin/dresses/new" class="btn btn-primary">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
            Yeni Gelinlik Ekle
        </a>
    </div>
    
    <div class="card-body p-0">
        <% if (dresses && dresses.length > 0) { %>
            <div class="table-responsive">
                <table class="table">
                    <thead>
                        <tr>
                            <th style="width: 80px;">Görsel</th>
                            <th>Model Adı</th>
                            <th>Kategori</th>
                            <th>Başlangıç Fiyatı</th>
                            <th>Etiket</th>
                            <th>Durum</th>
                            <th style="text-align: right;">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% dresses.forEach(dress => { %>
                            <tr>
                                <td>
                                    <% if (dress.image) { %>
                                        <img src="<%= dress.image %>" alt="<%= dress.name %>" class="table-img">
                                    <% } else { %>
                                        <div class="table-img" style="background: #eee; display:flex; align-items:center; justify-content:center;">
                                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#aaa" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline></svg>
                                        </div>
                                    <% } %>
                                </td>
                                <td class="fw-500"><%= dress.name %></td>
                                <td><span class="badge badge-secondary"><%= dress.category_name %></span></td>
                                <td><%= dress.price_text || '-' %></td>
                                <td>
                                    <% if (dress.tag) { %>
                                        <span class="badge badge-primary"><%= dress.tag %></span>
                                    <% } else { %>
                                        -
                                    <% } %>
                                </td>
                                <td>
                                    <% if (dress.is_active) { %>
                                        <span class="badge badge-success">Aktif</span>
                                    <% } else { %>
                                        <span class="badge badge-danger">Pasif</span>
                                    <% } %>
                                </td>
                                <td style="text-align: right;">
                                    <div class="d-flex justify-end gap-sm">
                                        <a href="/admin/dresses/edit/<%= dress.id %>" class="btn-icon" title="Düzenle">
                                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                                        </a>
                                        <form action="/admin/dresses/delete/<%= dress.id %>" method="POST" style="display: inline;" onsubmit="return confirm('Bu gelinliği silmek istediğinize emin misiniz? Bu işlem geri alınamaz.');">
                                            <button type="submit" class="btn-icon text-danger" title="Sil">
                                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        <% } else { %>
            <div class="empty-state">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="mb-sm text-muted"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
                <p>Henüz gelinlik eklenmemiş.</p>
                <a href="/admin/dresses/new" class="btn btn-outline mt-sm">İlk Gelinliği Ekle</a>
            </div>
        <% } %>
    </div>
</div>
