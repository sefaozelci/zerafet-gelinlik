<div class="card">
    <div class="card-header d-flex justify-between align-center">
        <h2 class="card-title"><%= isEdit ? 'Hizmeti Düzenle' : 'Yeni Hizmet Ekle' %></h2>
        <a href="/admin/services" class="btn btn-outline-sm">İptal / Geri Dön</a>
    </div>
    
    <div class="card-body">
        <form action="<%= isEdit ? '/admin/services/edit/' + service.id : '/admin/services/new' %>" method="POST">
            
            <div class="form-row">
                <div class="form-group">
                    <label for="title" class="form-label">Hizmet Adı *</label>
                    <input type="text" class="form-control" id="title" name="title" value="<%= isEdit ? service.title : '' %>" required>
                </div>
                
                <div class="form-group">
                    <label for="icon" class="form-label">İkon *</label>
                    <select class="form-control" id="icon" name="icon" required>
                        <option value="" disabled <%= !isEdit ? 'selected' : '' %>>İkon Seçin</option>
                        <option value="heart" <%= isEdit && service.icon === 'heart' ? 'selected' : '' %>>Kalp (Örn: Gelinlik Seçimi)</option>
                        <option value="tool" <%= isEdit && service.icon === 'tool' ? 'selected' : '' %>>Makas/Araç (Örn: Özel Tasarım)</option>
                        <option value="smile" <%= isEdit && service.icon === 'smile' ? 'selected' : '' %>>Gülümseme (Örn: Tadilat)</option>
                        <option value="image" <%= isEdit && service.icon === 'image' ? 'selected' : '' %>>Görsel/Ayna (Örn: Aksesuar)</option>
                        <option value="star" <%= isEdit && service.icon === 'star' ? 'selected' : '' %>>Yıldız (Örn: VIP)</option>
                        <option value="gift" <%= isEdit && service.icon === 'gift' ? 'selected' : '' %>>Hediye</option>
                    </select>
                </div>
            </div>

            <div class="form-group">
                <label for="description" class="form-label">Açıklama *</label>
                <textarea class="form-control" id="description" name="description" rows="3" required><%= isEdit ? service.description : '' %></textarea>
            </div>

            <h3 class="fw-500 mb-sm mt-md" style="font-family: var(--font-body); font-size: var(--fs-h4); border-bottom: 1px solid var(--clr-border); padding-bottom: 8px;">Özellikler (Maddeler)</h3>
            
            <% 
                let features = [];
                if (isEdit && service.features) {
                    try { features = JSON.parse(service.features); } catch(e) {}
                }
            %>
            
            <div class="form-group">
                <label for="feature1" class="form-label">Özellik 1</label>
                <input type="text" class="form-control" id="feature1" name="features[]" value="<%= features[0] || '' %>" placeholder="Örn: Birebir danışmanlık">
            </div>
            
            <div class="form-group">
                <label for="feature2" class="form-label">Özellik 2</label>
                <input type="text" class="form-control" id="feature2" name="features[]" value="<%= features[1] || '' %>" placeholder="Örn: 2 saatlik özel seans">
            </div>
            
            <div class="form-group">
                <label for="feature3" class="form-label">Özellik 3</label>
                <input type="text" class="form-control" id="feature3" name="features[]" value="<%= features[2] || '' %>" placeholder="Örn: Champagne ikramı">
            </div>

            <div class="form-row mt-md">
                <div class="form-group">
                    <label for="sort_order" class="form-label">Sıralama</label>
                    <input type="number" class="form-control" id="sort_order" name="sort_order" value="<%= isEdit ? service.sort_order : 0 %>">
                    <small class="form-text">Küçük sayı olanlar önce listelenir.</small>
                </div>

                <div class="form-group" style="display: flex; align-items: center;">
                    <label class="checkbox-wrapper mt-sm">
                        <input type="checkbox" name="is_featured" value="1" <%= (isEdit && service.is_featured) ? 'checked' : '' %>>
                        <span>Öne Çıkan Hizmet (Koyu renk vurgulu kart)</span>
                    </label>
                </div>
            </div>

            <div class="mt-md pt-sm" style="border-top: 1px solid var(--clr-border);">
                <button type="submit" class="btn btn-primary">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path><polyline points="17 21 17 13 7 13 7 21"></polyline><polyline points="7 3 7 8 15 8"></polyline></svg>
                    <%= isEdit ? 'Hizmeti Güncelle' : 'Hizmeti Kaydet' %>
                </button>
            </div>
        </form>
    </div>
</div>
