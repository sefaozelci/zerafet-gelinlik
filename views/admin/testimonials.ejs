<div class="card">
    <div class="card-header d-flex justify-between align-center">
        <h2 class="card-title">Müşteri Yorumları</h2>
        <a href="/admin/testimonials/new" class="btn btn-primary">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
            Yeni Yorum Ekle
        </a>
    </div>
    
    <div class="card-body p-0">
        <% if (testimonials && testimonials.length > 0) { %>
            <div class="table-responsive">
                <table class="table">
                    <thead>
                        <tr>
                            <th style="width: 50px;">Avatar</th>
                            <th>Müşteri Adı</th>
                            <th>Tarih</th>
                            <th>Puan</th>
                            <th>Yorum Özeti</th>
                            <th>Durum</th>
                            <th style="text-align: right;">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% testimonials.forEach(testi => { %>
                            <tr>
                                <td>
                                    <div style="background: linear-gradient(135deg, var(--clr-primary), var(--clr-accent)); color: #fff; width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 600; font-size: 0.8rem;">
                                        <%= testi.initials %>
                                    </div>
                                </td>
                                <td class="fw-500"><%= testi.name %></td>
                                <td><%= testi.date_text %></td>
                                <td>
                                    <span style="color: var(--clr-warning);">
                                        <%= '★'.repeat(testi.rating) %><%= '☆'.repeat(5 - testi.rating) %>
                                    </span>
                                </td>
                                <td>
                                    <div style="max-width: 250px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; font-style: italic;">
                                        "<%= testi.text %>"
                                    </div>
                                </td>
                                <td>
                                    <% if (testi.is_active) { %>
                                        <span class="badge badge-success">Aktif</span>
                                    <% } else { %>
                                        <span class="badge badge-danger">Pasif</span>
                                    <% } %>
                                </td>
                                <td style="text-align: right;">
                                    <div class="d-flex justify-end gap-sm">
                                        <a href="/admin/testimonials/edit/<%= testi.id %>" class="btn-icon" title="Düzenle">
                                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                                        </a>
                                        <form action="/admin/testimonials/delete/<%= testi.id %>" method="POST" style="display: inline;" onsubmit="return confirm('Bu yorumu silmek istediğinize emin misiniz?');">
                                            <button type="submit" class="btn-icon text-danger" title="Sil">
                                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        <% } else { %>
            <div class="empty-state">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="mb-sm text-muted"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
                <p>Henüz müşteri yorumu eklenmemiş.</p>
                <a href="/admin/testimonials/new" class="btn btn-outline mt-sm">İlk Yorumu Ekle</a>
            </div>
        <% } %>
    </div>
</div>
